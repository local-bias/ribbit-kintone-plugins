{
  "name": "uid",
  "version": "2.0.1",
  "author": "ribbit",
  "license": "MIT",
  "scripts": {
    "init": "plugin init && plugin genkey",
    "build:css-desktop": "pnpm dlx @tailwindcss/cli -i ./src/styles/desktop.css -o ./.plugin/contents/desktop.css --minify",
    "build:css-config": "pnpm dlx @tailwindcss/cli -i ./src/styles/config.css -o ./.plugin/contents/config.css --minify",
    "build:js": "plugin build",
    "build": "pnpm run build:js && concurrently \"pnpm:build:css-*\" && plugin zip",
    "standalone": "pnpm run build && plugin zip --env standalone",
    "dev": "plugin dev --cert-dir ~/config/cert"
  },
  "browser": {
    "path": false
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@emotion/css": "^11.13.5",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@konomi-app/kintone-utilities": "^6.3.0",
    "@konomi-app/kintone-utilities-jotai": "^2.6.0",
    "@konomi-app/kintone-utilities-react": "^3.5.3",
    "@konomi-app/ui": "^5.11.0",
    "@konomi-app/ui-react": "^3.0.1",
    "@mui/icons-material": "^9.0.0",
    "@mui/material": "^9.0.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "jotai": "^2.19.1",
    "jotai-optics": "^0.4.0",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.9",
    "notistack": "^3.0.2",
    "optics-ts": "^2.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-error-boundary": "^6.1.1",
    "tiny-invariant": "^1.3.3",
    "uuid": "^14.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kintone/dts-gen": "^9.0.5",
    "@konomi-app/k2": "^4.2.0",
    "@konomi-app/prettier-config": "^1.1.2",
    "@types/luxon": "^3.7.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@uiw/react-json-view": "2.0.0-alpha.42",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3"
  },
  "prettier": "@konomi-app/prettier-config"
}
