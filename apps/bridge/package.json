{
  "name": "bridge",
  "version": "2.1.0",
  "author": "ribbit",
  "license": "MIT",
  "scripts": {
    "init": "plugin init && plugin genkey",
    "build:css-desktop": "pnpm dlx @tailwindcss/cli -i ./src/styles/desktop.css -o ./.plugin/contents/desktop.css --minify",
    "build:css-config": "pnpm dlx @tailwindcss/cli -i ./src/styles/config.css -o ./.plugin/contents/config.css --minify",
    "build": "plugin build && concurrently \"pnpm:build:*\" && plugin zip",
    "standalone": "plugin build && concurrently \"pnpm:build:*\" && plugin zip --env standalone",
    "dev:js": "plugin dev --ppk ~/config/kintone-plugin-dev.ppk --cert-dir ~/config/cert",
    "dev:css-desktop": "pnpm dlx @tailwindcss/cli -i ./src/styles/desktop.css -o ./.plugin/dev/desktop.css --watch",
    "dev:css-config": "pnpm dlx @tailwindcss/cli -i ./src/styles/config.css -o ./.plugin/dev/config.css --watch",
    "dev": "concurrently \"pnpm:dev:*\""
  },
  "browser": {
    "path": false
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@konomi-app/kintone-utilities": "^6.2.0",
    "@konomi-app/kintone-utilities-jotai": "catalog:",
    "@konomi-app/kintone-utilities-react": "catalog:",
    "@konomi-app/ui": "^5.11.0",
    "@konomi-app/ui-react": "^3.0.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@repo/jotai": "workspace:*",
    "@repo/utils": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "immer": "^11.1.4",
    "jotai": "catalog:",
    "jotai-eager": "catalog:",
    "lucide-react": "^1.8.0",
    "luxon": "^3.7.2",
    "nanoid": "^5.1.7",
    "notistack": "^3.0.2",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-error-boundary": "^6.1.1",
    "sweetalert2": "^11.26.24",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tiny-invariant": "^1.3.3",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kintone/dts-gen": "^9.0.4",
    "@konomi-app/k2": "^4.2.0",
    "@repo/typescript-config": "workspace:*",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.1",
    "tailwindcss": "^4.2.2",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2"
  }
}
